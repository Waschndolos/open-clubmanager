{
  "compilerOptions": {
    "moduleResolution": "bundler",
    "module": "es2020",
    "target": "es2020",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "moduleDetection": "force",
    "types": ["node"],
    "typeRoots": ["../node_modules/@types"]
  },
  "include": ["main.ts", "preload.cts", "storage/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}